// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String    // encrypted
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

// Per-shop configuration for the support copilot draft generator.
model SupportSettings {
  shop                  String   @id
  signatureName         String   @default("Customer Support")
  brandName             String   @default("")
  tone                  String   @default("friendly")     // friendly | formal | neutral
  language              String   @default("auto")         // auto | fr | en
  closingPhrase         String   @default("")
  shareTrackingNumber   Boolean  @default(true)
  customerGreetingStyle String   @default("auto")         // auto | first_name | full_name | neutral
  refundPolicy          String   @default("")
  updatedAt             DateTime @updatedAt
}

model MailConnection {
  shop           String   @id
  provider       String   @default("gmail") // "gmail" | "zoho"
  email          String   @default("")      // connected email address
  // Lowercased addresses from which the merchant can send via this account
  // (e.g. support@, contact@ aliases configured in Zoho/Gmail/Outlook).
  // Populated at OAuth completion by querying the provider, refreshed at
  // each token renewal. Used by outgoing-detection to mark merchant replies
  // as outgoing without relying on a self-reinforcing pool of prior data.
  // JSON-encoded String[] for cross-DB portability (Prisma's String[] is
  // postgres-only on this version, and the column is small).
  outgoingAliases String  @default("[]")
  accessToken    String   // encrypted
  refreshToken   String   // encrypted
  tokenExpiry    DateTime
  historyId      String?  // Gmail only — incremental sync cursor
  deltaToken     String?  // Outlook only — Microsoft Graph delta link (full URL)
  lastSyncAt     DateTime?
  lastSyncError  String?  // last top-level sync error message, if any
  syncCancelledAt DateTime? // set by the user to abort a running sync
  zohoAccountId  String?  // Zoho only — needed for API calls
  // --- Backend auto-sync (spec §10) -------------------------------------
  autoSyncEnabled          Boolean  @default(true)
  autoSyncIntervalMinutes  Int      @default(5)
  // --- Onboarding historical backfill (spec §11) ------------------------
  onboardingBackfillDoneAt DateTime?
  onboardingBackfillDays   Int      @default(60)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([autoSyncEnabled, lastSyncAt])
}

// Canonical thread: a normalized conversation identity that may group
// several provider threadIds together (Zoho splits a conversation when
// the subject changes; Gmail may also fragment under rare conditions).
// All cross-message logic (classification, state, backfill) should key
// off Thread.id rather than the provider's raw threadId.
model Thread {
  id             String   @id @default(cuid())
  shop           String
  provider       String   // "gmail" | "zoho" — provider that first created the thread
  // Fast-path cached stats (maintained by the resolver on ingestion):
  lastMessageAt  DateTime // receivedAt of the true latest message (any direction)
  lastMessageId  String?  // IncomingEmail.id of the true latest message
  firstMessageAt DateTime // receivedAt of the oldest message in the canonical thread
  messageCount   Int      @default(0)
  // Normalized subject kept for debugging / future heuristic merges.
  subjectKey     String   @default("")
  // --- Consolidated identifier resolution at thread level ---------------
  // Merged from per-message extractions. Populated/updated by the
  // thread-identifiers module on every ingestion. Business code should
  // prefer these over re-parsing the full thread.
  resolvedOrderNumber    String?  // e.g. "1234" (without #)
  resolvedTrackingNumber String?
  resolvedEmail          String?  // customer email
  resolvedCustomerName   String?
  resolutionConfidence   String   @default("none") // none | low | medium | high
  resolvedFromMessageId  String?  // IncomingEmail.id that produced the strongest signal
  // --- Thread-level classification (spec §4, §5, §7) --------------------
  // supportNature is "sticky": once set to `confirmed_support`, never
  // downgrades to `non_support` automatically. See thread-state.ts.
  supportNature          String   @default("unknown")
  //                                // unknown | non_support | probable_support | confirmed_support | mixed | needs_review
  supportNatureUpdatedAt DateTime?
  // Orthogonal operational state — can move freely both ways.
  operationalState         String   @default("open")
  //                                  // open | waiting_customer | waiting_merchant | resolved | no_reply_needed
  previousOperationalState String?  // last state before a manual move to resolved
  operationalStateUpdatedAt DateTime?
  // Structured thread state (spec §9). JSON blob consumed by the
  // classifier/draft as compact context. Shape: {
  //   orderResolved, trackingResolved, lastCustomerIntent, lastAgentAction,
  //   awaitingCustomer, awaitingMerchant, openIssue, replyNeeded,
  //   needsReviewReason, trueLatestMessageId, targetMessageId, ...
  // }
  structuredState        String   @default("{}")
  // Prose summary generated by the LLM — only for long/ambiguous threads.
  summaryText            String?
  summaryUpdatedAt       DateTime?
  // --- History completeness (spec §12) ----------------------------------
  historyStatus          String   @default("unknown") // complete | partial | unknown
  oldestSyncedMessageAt  DateTime?
  backfillAttemptedAt    DateTime?
  // --- Manual override snapshot (survives `handleResync`) --------------
  // JSON shape: { intents?: SupportIntent[]; intentsAt?: ISO; order?: OrderFacts|null; orderAt?: ISO }
  // Captured by handleResync before wiping IncomingEmail rows; consumed
  // by the next analysis pass for this thread, then cleared.
  preservedManualOverridesJson String?
  // --- GDPR tombstone (customers/redact) -------------------------------
  // When a customer requests deletion under GDPR, we wipe all PII fields
  // (resolved*, subjectKey, structuredState, summaryText, preservedManual…)
  // and delete the related messages/drafts. The Thread row itself is kept
  // as a tombstone so the merchant sees a placeholder in the inbox rather
  // than a confusing gap. `redactedAt` non-null signals tombstone state.
  redactedAt     DateTime?
  redactedReason String?  // e.g. "gdpr_customer_request"
  // --- Billing (per-conversation) -----------------------------------
  // Timestamp of the first successful Tier 3 analysis on this thread.
  // Used by the billing counter `markThreadAnalyzedIfFirst` to guarantee
  // one billing increment per thread regardless of how many times Tier 3
  // re-runs (new messages, refresh-stale, user-triggered re-analyse).
  analyzedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  providerIds  ThreadProviderId[]
  messages     IncomingEmail[]
  stateHistory ThreadStateHistory[]

  @@index([shop, lastMessageAt])
  @@index([shop, firstMessageAt])
  @@index([shop, supportNature])
  @@index([shop, operationalState])
  @@index([shop, operationalState, operationalStateUpdatedAt])
  // Helps detect duplicate canonical threads when ThreadProviderId backfill races.
  @@index([shop, provider, subjectKey])
  @@index([shop, analyzedAt])
}

// Mapping from a provider-native threadId to the canonical Thread.id.
// A Thread may have N provider threadIds attached (Zoho split case).
model ThreadProviderId {
  id                String   @id @default(cuid())
  canonicalThreadId String
  shop              String
  provider          String
  providerThreadId  String
  createdAt         DateTime @default(now())

  canonical Thread @relation(fields: [canonicalThreadId], references: [id], onDelete: Cascade)

  @@unique([shop, provider, providerThreadId])
  @@index([canonicalThreadId])
}

model IncomingEmail {
  id               String   @id @default(cuid())
  shop             String
  externalMessageId String
  // Provider-native thread identifier (Gmail threadId / Zoho threadId).
  // Kept for diagnostics; logic should prefer canonicalThreadId.
  threadId         String   @default("")
  // Canonical thread this message belongs to. Nullable during backfill
  // and for legacy rows; new rows always have it set by the resolver.
  canonicalThreadId String?
  // RFC 5322 headers useful for thread reconciliation across providers.
  rfcMessageId     String   @default("")
  inReplyTo        String   @default("")
  rfcReferences    String   @default("") // space-separated Message-IDs
  // Per-message regex extraction cached at ingestion time. JSON of
  // { orderNumber?, trackingNumber?, email?, customerName? }. The thread
  // consolidates these into Thread.resolved* fields.
  extractedIdentifiers String @default("{}")
  fromAddress      String
  fromName         String   @default("")
  subject          String
  snippet          String   @default("")
  bodyText         String   @default("")
  receivedAt       DateTime
  labelIds         String   @default("[]")   // JSON array of provider label IDs e.g. ["INBOX","CATEGORY_PROMOTIONS"]
  tier1Result      String?  // "passed" | "filtered:<reason>"
  tier2Result      String?  // "support_client" | "probable_non_client" | "incertain"
  isKnownCustomer  Boolean  @default(false)
  processingStatus String   @default("pending") // pending | filtering | classified | analyzed | error
  analysisResult   String?  // JSON blob
  // Top-level fields promoted out of analysisResult for cheap SQL
  // queries (dashboards, rule engines, QA). Must stay in sync with
  // the JSON blob — written at the same time in the pipeline.
  detectedIntent      String?  // SupportIntent enum value
  analysisConfidence  String?  // "high" | "medium" | "low"
  // Timestamp of the last full analysis (Shopify + tracking refresh).
  // Used to:
  //   - drive the daily auto-refresh of "to handle" threads,
  //   - trigger an automatic refresh when the user generates / refines
  //     a draft and the last analysis is older than 1h,
  //   - show the merchant when the data was last refreshed.
  lastAnalyzedAt      DateTime?
  errorMessage     String?
  // HTML body of the email (sanitized at ingestion time, may be empty)
  bodyHtml         String   @default("")
  hasAttachments   Boolean  @default(false)
  // Aggregated LLM cost tracking (sum of all LLM calls on this email)
  llmTokensTotal   Int      @default(0)
  llmCostUsd       Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  thread Thread? @relation(fields: [canonicalThreadId], references: [id], onDelete: SetNull)
  replyDraft   ReplyDraft?
  incomingAttachments IncomingEmailAttachment[]

  @@unique([shop, externalMessageId])
  @@index([shop, processingStatus])
  @@index([shop, receivedAt])
  @@index([canonicalThreadId, receivedAt])
  // Plain canonicalThreadId index for COUNT(*) / simple lookups that don't
  // need the receivedAt suffix.
  @@index([canonicalThreadId])
  @@index([shop, rfcMessageId])
  @@index([shop, detectedIntent])
  @@index([shop, analysisConfidence])
  @@index([shop, lastAnalyzedAt])
  // Covers `refresh-stale-analyses` query that filters on processingStatus
  // AND lastAnalyzedAt — pure lastAnalyzedAt index leaves the status filter
  // to a heap scan.
  @@index([shop, processingStatus, lastAnalyzedAt])
}

// Attachments and inline images extracted from incoming emails.
// Small inline images (< 200KB) are stored as base64 in inlineData;
// larger files must be fetched on-demand via the provider API.
model IncomingEmailAttachment {
  id               String        @id @default(cuid())
  shop             String
  emailId          String
  email            IncomingEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)
  fileName         String
  mimeType         String
  sizeBytes        Int
  contentId        String?       // CID for inline images (without angle brackets)
  disposition      String        // "attachment" | "inline"
  inlineData       String?       // base64-encoded for small files
  provider         String        // "gmail" | "zoho"
  providerMsgId    String        // Gmail/Zoho message ID
  providerAttachId String?       // Gmail/Zoho attachmentId (null for small inline data)
  providerFolderId String?       // Zoho: folderId (required for attachment download URL)
  createdAt        DateTime      @default(now())

  @@index([shop])
  @@index([emailId])
}

model ReplyDraft {
  id          String   @id @default(cuid())
  shop        String
  emailId     String   @unique
  email       IncomingEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)

  body        String?
  bodyHistory Json     @default("[]")

  subject     String?
  cc          String?
  bcc         String?
  replyMode   String   @default("thread")

  attachments DraftAttachment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Retrospective draft-usage bucket. null = pending (no outgoing synced yet).
  /// Values: "as_is" | "edited" | "ignored"
  heuristicBucket      String?
  /// Timestamp of last heuristic computation.
  heuristicComputedAt  DateTime?

  @@index([shop])
  @@index([shop, heuristicBucket, createdAt])
}

model DraftAttachment {
  id                  String     @id @default(cuid())
  shop                String
  replyDraftId        String
  replyDraft          ReplyDraft @relation(fields: [replyDraftId], references: [id], onDelete: Cascade)

  fileName            String
  mimeType            String
  sizeBytes           Int
  source              String     // "upload" | "thread"
  storagePath         String?
  threadAttachmentRef String?

  createdAt           DateTime   @default(now())

  @@index([shop])
  @@index([replyDraftId])
}

// Granular log of every OpenAI call. Enables precise cost attribution
// per email / thread / call-site (classifier, llm-parser, llm-draft, …).
model LlmCallLog {
  id              String   @id @default(cuid())
  shop            String
  emailId         String?  // incomingEmail.id when applicable
  threadId        String?  // email threadId for thread-level aggregation
  callSite        String   // "classifier" | "llm-parser" | "llm-draft" | "refine-draft" | "tracking-agent" | "context-crawler"
  model           String
  promptTokens    Int
  completionTokens Int
  totalTokens     Int
  costUsd         Float
  durationMs      Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([shop])
  @@index([shop, createdAt])
  @@index([emailId])
  @@index([threadId])
}

// Audit trail of every operationalState transition on a Thread.
// Populated whenever Thread.operationalState changes. Used by the
// dashboard stats page to compute conversation trends over time.
// onDelete: Cascade ensures rows are removed when a Thread is deleted
// (e.g. GDPR shop/redact webhook).
model ThreadStateHistory {
  id        String   @id @default(cuid())
  shop      String
  threadId  String
  fromState String?
  toState   String
  changedAt DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([shop, changedAt])
  @@index([threadId, changedAt])
  // Covering index for dashboard `getAlerts` (filters on fromState + toState).
  @@index([shop, fromState, toState, changedAt])
}

// Per-user preference (UI language, etc.). Keyed by Shopify userId + shop
// so that agents on the same shop can have independent preferences.
model UserPreference {
  id         String   @id @default(cuid())
  userId     String
  shop       String
  uiLanguage String   @default("en")
  updatedAt  DateTime @updatedAt

  @@unique([userId, shop])
  @@index([shop])
}

// Durable background job for anything the auto-sync worker should
// pick up off the hot request path (sync, manual backfill, resync).
// Web actions enqueue rows; the in-process auto-sync tick claims and
// processes them. Surviving a restart is the whole point — do not
// replace with in-memory Promises.
model SyncJob {
  id           String    @id @default(cuid())
  shop         String
  kind         String    // "sync" | "backfill" | "resync"
  params       String    @default("{}") // JSON payload (e.g. { afterDate })
  status       String    @default("pending") // pending | running | done | error
  attempts     Int       @default(0)
  lastError    String?
  // Populated by markJobFailed: exponential backoff — job stays "pending"
  // but claimNextJob skips it until this timestamp is reached.
  nextRetryAt  DateTime?
  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?

  @@index([shop, status])
  @@index([status, nextRetryAt])
}

// Sliding-window rate-limit counters. One row per (key, kind) — the
// rate-limit module increments `count` and resets when `windowStart` is
// older than the window. Cheap because all access goes through one upsert
// + at most one delete-old-rows housekeeping query.
model RateLimitBucket {
  // Logical key, e.g. shop domain for per-shop limits, or IP address for
  // per-IP limits on public routes.
  key         String
  // Free-form identifier for what's being rate-limited
  // (e.g. "reply-draft", "mail-auth").
  kind        String
  count       Int       @default(0)
  windowStart DateTime  @default(now())

  @@id([key, kind])
  @@index([windowStart])
}

// Per-shop monthly usage counter for billing quotas.
// One row per (shop, periodStart) — enforced via unique constraint.
// periodStart is always 00:00:00 UTC of the 1st of the month.
model BillingUsage {
  id           String   @id @default(cuid())
  shop         String
  periodStart  DateTime
  // Renamed from draftsCount. Each successful first-time Tier 3 on a
  // Thread increments this by 1 via markThreadAnalyzedIfFirst.
  analyzedThreadsCount Int @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([shop, periodStart])
  @@index([shop])
}

// Scheduled plan changes (downgrades). Applied at effectiveAt by a job.
// Upgrades are immediate via Shopify Billing API and don't use this table.
model BillingScheduledChange {
  id           String    @id @default(cuid())
  shop         String
  fromPlan     String
  toPlan       String
  effectiveAt  DateTime
  createdAt    DateTime  @default(now())
  appliedAt    DateTime?
  cancelledAt  DateTime?

  @@index([shop])
  @@index([effectiveAt, appliedAt])
}

// Per-shop billing flags (internal/dev shops bypass entitlement checks).
// installDate is used to compute trial expiry when no Shopify subscription exists yet.
model ShopFlag {
  shop                  String    @id
  isInternal            Boolean   @default(false)
  // First time the shop ever installed the app. Immutable after creation.
  // Used as trial-start anchor so uninstall/reinstall doesn't reset trial.
  firstInstallDate      DateTime  @default(now())
  onboardingCompletedAt DateTime?
  checklistDismissedAt  DateTime?
  updatedAt             DateTime  @updatedAt
}
